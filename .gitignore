# --- Python ---
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# --- Environments ---
.venv/
venv/
env/

# --- Markdown docs: keep only README.md tracked ---
# plan.md, IMPLEMENTATION_SUMMARY.md, QUICK_REFERENCE.md etc. are working
# notes, not meant to be published/tracked.
*.md
!README.md

# --- Data: heavy, regenerable via scripts/download_sdss.py ---
data/*.csv

# --- Results: regenerated by generate_results.py / scripts/run_leakage_experiment.py ---
# Everything in results/ is ignored by default (it's reproducible output), except a
# curated subset tracked so the key figures render in README.md on GitHub without
# requiring a local run first. The rest (confusion matrices, training history, ROC
# curves, k-fold plot, MC Dropout plot, UMAP projection) regenerate locally.
results/*
!results/00_results_summary.png
!results/model_comparison.png
!results/feature_importance.png
!results/leakage_regime_comparison.png
!results/leakage_permutation_importance.png
!results/leakage_regime_summary.csv
!results/sdss_examples
results/sdss_examples/*
!results/sdss_examples/00_galaxy_objid_1237646796526585237.jpg
!results/sdss_examples/01_qso_objid_1237646645686501848.jpg
!results/sdss_examples/02_star_objid_1237646586639353069.jpg

# --- OS/editor cruft ---
.DS_Store
*.swp
